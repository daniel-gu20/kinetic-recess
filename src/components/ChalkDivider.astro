---
// Signature device: a hand-drawn chalk hopscotch ladder used as a section divider.
interface Props { class?: string }
const { class: className = "" } = Astro.props;
---
<div class:list={["w-full flex justify-center py-stack-md", className]} aria-hidden="true">
  <svg width="220" height="48" viewBox="0 0 220 48" fill="none" class="text-on-surface/25" xmlns="http://www.w3.org/2000/svg">
    <!-- single squares -->
    <rect x="92" y="2" width="36" height="20" stroke="currentColor" stroke-width="2" transform="rotate(-1.5 110 12)"/>
    <rect x="92" y="24" width="36" height="20" stroke="currentColor" stroke-width="2" transform="rotate(1 110 34)"/>
    <!-- side-by-side squares -->
    <rect x="54" y="2" width="36" height="20" stroke="currentColor" stroke-width="2" transform="rotate(1 72 12)"/>
    <rect x="130" y="2" width="36" height="20" stroke="currentColor" stroke-width="2" transform="rotate(-1 148 12)"/>
    <!-- chalk dust strokes -->
    <path d="M4 38 C 30 30, 30 18, 50 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="1 7"/>
    <path d="M216 10 C 190 18, 190 30, 170 34" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="1 7"/>
  </svg>
</div>

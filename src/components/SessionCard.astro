---
import type { Session } from "../data/site";
import { CTA } from "../data/site";
interface Props { session: Session }
const { session } = Astro.props;
const soldOut = session.spotsLeft <= 0;
const low = session.spotsLeft > 0 && session.spotsLeft <= 4;
---
<article class="group bg-surface-container-lowest border border-border overflow-hidden flex flex-col hover:border-secondary-fixed transition-colors">
  <div class="relative h-48 overflow-hidden">
    <img
      src={session.image}
      alt={`${session.gameName} at ${session.park}, floodlit at night`}
      loading="lazy"
      width="1184"
      height="864"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute top-4 left-4 bg-primary text-on-primary px-3 py-1 font-label-bold text-[12px] uppercase tracking-wide">
      {session.dayOfWeek.slice(0, 3)} • {session.startTime}
    </div>
    {soldOut && (
      <div class="absolute top-4 right-4 bg-error text-on-error px-3 py-1 font-label-bold text-[12px] uppercase tracking-wide">Sold out</div>
    )}
  </div>

  <div class="p-6 flex flex-col flex-1">
    <div class="flex justify-between items-start gap-3 mb-3">
      <div>
        <h3 class="font-headline-md text-[22px] leading-tight text-primary uppercase">{session.gameName}</h3>
        <p class="font-label-bold text-label-bold text-on-surface-variant flex items-center gap-1 mt-1">
          <span class="material-symbols-outlined text-[16px]">location_on</span>
          {session.park}
        </p>
        <p class="text-[12px] text-on-surface-variant/80 mt-1 uppercase tracking-wide">
          {session.neighborhood} • {session.difficulty} • {session.sessionType}
        </p>
      </div>
      <div class:list={[
        "px-3 py-2 flex flex-col items-center leading-none shrink-0",
        soldOut ? "bg-surface-container-highest text-on-surface-variant" : "bg-secondary-fixed text-on-secondary-fixed",
      ]}>
        <span class="font-display text-[24px]">{String(session.spotsLeft).padStart(2, "0")}</span>
        <span class="font-label-bold text-[10px] uppercase">Spots</span>
      </div>
    </div>

    <p class="font-body-md text-body-md text-on-surface-variant mb-4 flex-1">{session.blurb}</p>
    {low && <p class="font-label-bold text-[12px] uppercase text-error mb-3">Almost full — {session.spotsLeft} left</p>}

    <div class="flex items-center justify-between pt-4 border-t border-border mt-auto">
      <span class="font-label-bold text-label-bold text-on-surface-variant uppercase">{session.price}</span>
      {soldOut ? (
        <button disabled class="bg-surface-container-highest text-on-surface-variant cursor-not-allowed px-6 py-2 font-label-bold uppercase">Waitlist</button>
      ) : (
        <a href={CTA.primary.href} class="bg-primary text-on-primary px-6 py-2 font-label-bold uppercase hover:bg-secondary-fixed hover:text-on-secondary-fixed transition-colors">Grab a spot</a>
      )}
    </div>
  </div>
</article>

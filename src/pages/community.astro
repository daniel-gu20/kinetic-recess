---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import { COMMUNITY_NIGHTS, CTA } from "../data/site";
---

<Layout title="Community Nights" description="Free public playground sessions, funded by corporate bookings. Same parks, same games, no fee." path="/community">
  <!-- Hero -->
  <section data-floodlight class="relative h-[44vh] min-h-[340px] flex items-end overflow-hidden">
    <img src="/images/kickball.webp" alt="A packed free community kickball night under park lights" fetchpriority="high" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 scrim-bottom"></div>
    <div class="relative z-10 w-full max-w-(--container-max-width) mx-auto px-margin-mobile md:px-margin-desktop pb-stack-md pt-28">
      <p class="font-accent-script text-[24px] text-[#F4EFE2]/85">Under the lights, for the people</p>
      <h1 class="font-display text-[clamp(2.5rem,8vw,5.5rem)] leading-none uppercase text-on-primary">Community Nights</h1>
      <p class="font-body-lg text-body-lg text-on-primary/85 mt-3 max-w-xl">Free public sessions funded by corporate bookings. Same parks, same games, no fee — just save a spot so we know how many foam balls to bring.</p>
    </div>
  </section>

  <!-- Nights list -->
  <section class="max-w-(--container-max-width) mx-auto px-margin-mobile md:px-margin-desktop py-stack-xl">
    <h2 class="font-display text-[clamp(1.8rem,5vw,3rem)] leading-none uppercase text-primary mb-stack-md">Upcoming free sessions</h2>
    <div class="grid md:grid-cols-3 gap-gutter">
      {COMMUNITY_NIGHTS.map((n) => (
        <article class="bg-surface-container-lowest border border-border flex flex-col">
          <div class="bg-primary text-on-primary px-6 py-4 flex items-baseline justify-between">
            <span class="font-display text-[28px] uppercase text-[#F4EFE2]">{n.date}</span>
            <span class="font-label-bold text-[12px] uppercase text-on-primary/70">{n.spotsLeft} spots · free</span>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="font-headline-md text-[22px] uppercase text-primary">{n.gameName}</h3>
            <p class="font-label-bold text-label-bold text-on-surface-variant flex items-center gap-1 mt-1">
              <Icon name="location" class="w-4 h-4 shrink-0" />{n.park}
            </p>
            <p class="font-body-md text-body-md text-on-surface-variant mt-3 flex-1">{n.blurb}</p>
            <p class="font-accent-script text-[18px] text-secondary mt-3">{n.funder}</p>
            <button
              type="button"
              data-reserve
              data-session-name={n.gameName}
              data-session-day={n.date}
              data-park={n.park}
              data-type="community"
              class="mt-5 text-center bg-secondary-fixed text-on-secondary-fixed px-6 py-3 font-display text-[18px] uppercase tracking-wide hover:bg-secondary-fixed-dim transition-colors"
            >{CTA.free.label}</button>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Don't watch from the sidelines band -->
  <section class="bg-primary text-on-primary">
    <div class="max-w-(--container-max-width) mx-auto px-margin-mobile md:px-margin-desktop py-stack-xl text-center">
      <h2 class="font-display text-[clamp(2.2rem,6vw,4.5rem)] leading-[0.95] uppercase">Don't watch from <span class="text-[#F4EFE2]">the sidelines.</span></h2>
      <p class="font-body-lg text-body-lg text-on-primary/80 mt-4 max-w-xl mx-auto">Want more free nights on the calendar? They're paid for by offices booking team games. Tell yours.</p>
      <a href={CTA.corporate.href} class="inline-block mt-7 bg-secondary-fixed text-on-secondary-fixed px-8 py-4 font-display text-[20px] uppercase tracking-wide hover:bg-secondary-fixed-dim transition-colors">{CTA.corporate.label}</a>
    </div>
  </section>
</Layout>

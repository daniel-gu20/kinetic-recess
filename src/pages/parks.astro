---
import Layout from "../layouts/Layout.astro";
import { PARKS, SITE, CTA } from "../data/site";

const jsonLd = PARKS.map((p) => ({
  "@context": "https://schema.org",
  "@type": "SportsActivityLocation",
  name: `${SITE.name} — ${p.name}`,
  address: { "@type": "PostalAddress", addressLocality: "Toronto", addressRegion: "ON", addressCountry: "CA" },
  containedInPlace: { "@type": "Park", name: p.name },
  openingHours: "Tu-Su 18:00-21:00",
}));

// Park markers for the interactive map (real coordinates).
const markers = PARKS.map((p) => ({ name: p.name, neighborhood: p.neighborhood, lat: p.lat, lng: p.lng }));
---

<Layout title="Find a Park" description="Park locations, after-hours access notes, and what to bring. Trinity Bellwoods, Dufferin Grove, Christie Pits, Riverdale." path="/parks" headerSolid={true}>
  <section class="grid lg:grid-cols-2">
    <!-- Park list side -->
    <div class="px-margin-mobile md:px-margin-desktop py-stack-md lg:pt-32 order-2 lg:order-1">
      <p class="font-accent-script text-[24px] text-secondary">{SITE.location}</p>
      <h1 class="font-display text-[clamp(2.5rem,7vw,5rem)] leading-[0.9] uppercase text-primary">Night courts</h1>
      <p class="font-body-md text-body-md text-on-surface-variant mt-3 mb-stack-md max-w-md">{SITE.hours} We rotate through permitted parks — every session listing names the park and meeting spot.</p>

      <div class="flex flex-col gap-gutter">
        {PARKS.map((p) => (
          <article class="flex flex-col sm:flex-row border border-border bg-surface-container-lowest overflow-hidden">
            <img src={p.image} alt={`${p.name} under floodlights at night`} loading="lazy" class="w-full sm:w-40 h-40 sm:h-auto object-cover shrink-0" />
            <div class="p-5">
              <div class="flex items-center justify-between gap-3">
                <h2 class="font-headline-md text-[20px] uppercase text-primary">{p.name}</h2>
                <span class="font-label-bold text-[11px] uppercase text-on-surface-variant shrink-0">{p.neighborhood}</span>
              </div>
              <p class="font-body-md text-[14px] text-on-surface-variant mt-2"><span class="font-semibold uppercase text-on-surface text-[12px]">Access · </span>{p.access}</p>
              <p class="font-body-md text-[14px] text-on-surface-variant mt-1.5"><span class="font-semibold uppercase text-on-surface text-[12px]">Bring · </span>{p.bring}</p>
            </div>
          </article>
        ))}
      </div>

      <a href={CTA.primary.href} class="inline-block mt-stack-md bg-secondary-fixed text-on-secondary-fixed px-8 py-4 font-display text-[20px] uppercase tracking-wide hover:bg-secondary-fixed-dim transition-colors">{CTA.primary.label}</a>
    </div>

    <!-- Map side -->
    <div class="relative min-h-[55vh] lg:min-h-full bg-primary order-1 lg:order-2 lg:sticky lg:top-0 lg:h-screen">
      <div id="park-map" class="absolute inset-0 z-0"></div>
      <div class="absolute top-6 left-6 z-[500] bg-primary text-on-primary px-4 py-2 font-label-bold text-[12px] uppercase pointer-events-none">
        Active recess points · Lit status 100%
      </div>
      <!-- Loading placeholder until Leaflet initialises -->
      <div id="map-loading" class="absolute inset-0 z-[400] flex items-center justify-center bg-primary text-on-primary/60 font-label-bold text-[12px] uppercase tracking-wide">
        Lighting up the map…
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ markers }}>
  let started = false;
  const mapEl = document.getElementById("park-map");

  function loadCss(href) {
    return new Promise((resolve) => {
      const l = document.createElement("link");
      l.rel = "stylesheet";
      l.href = href;
      l.onload = () => resolve();
      document.head.appendChild(l);
    });
  }
  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const s = document.createElement("script");
      s.src = src;
      s.onload = () => resolve();
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  async function initMap() {
    if (started || !mapEl) return;
    started = true;
    try {
      await loadCss("https://unpkg.com/leaflet@1.9.4/dist/leaflet.css");
      await loadScript("https://unpkg.com/leaflet@1.9.4/dist/leaflet.js");
      const L = window.L;
      const map = L.map(mapEl, { scrollWheelZoom: false, attributionControl: true });
      L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png", {
        attribution: '&copy; OpenStreetMap &copy; CARTO',
        maxZoom: 19,
      }).addTo(map);

      const pin = L.divIcon({
        className: "",
        html: '<div style="transform:translate(-50%,-100%)"><svg width="34" height="34" viewBox="0 0 24 24" fill="#ffe74c" stroke="#11192e" stroke-width="1.2" style="filter:drop-shadow(0 1px 2px rgba(0,0,0,.5))"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg></div>',
        iconSize: [0, 0],
      });

      const pts = [];
      markers.forEach((m) => {
        L.marker([m.lat, m.lng], { icon: pin })
          .addTo(map)
          .bindPopup(`<strong>${m.name}</strong><br>${m.neighborhood}`);
        pts.push([m.lat, m.lng]);
      });
      map.fitBounds(pts, { padding: [60, 60] });
      document.getElementById("map-loading")?.remove();
    } catch (e) {
      const ld = document.getElementById("map-loading");
      if (ld) ld.textContent = "Map unavailable — see the park list.";
      console.error("Map failed to load:", e);
    }
  }

  // Load when the map scrolls into view (keeps it off the critical path).
  const check = () => {
    if (!mapEl) return;
    const r = mapEl.getBoundingClientRect();
    if (r.top < (window.innerHeight || 800) * 1.1 && r.bottom > 0) {
      initMap();
      window.removeEventListener("scroll", check);
    }
  };
  window.addEventListener("scroll", check, { passive: true });
  check();
</script>

# Wix Headless credentials — pull the real values with `wix env pull`.
# Do NOT commit the populated .env.local (it is gitignored).
WIX_CLOUD_PROVIDER=
WIX_CLIENT_ID=
WIX_CLIENT_INSTANCE_ID=
WIX_CLIENT_PUBLIC_KEY=
WIX_CLIENT_SECRET=

# Email (Resend) — optional; forms work without it, just no emails sent.
RESEND_API_KEY=
RESEND_FROM=Kinetic Recess <hello@kineticrecess.com>
TEAM_EMAIL=
